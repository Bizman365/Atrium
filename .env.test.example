# Test database isolation
#
# Tests MUST use TEST_DATABASE_URL and MUST NOT run against production DATABASE_URL.
# Use a dedicated Neon branch named "test" (or another clearly isolated branch).
# Keep real credentials in packages/database/.env.test or your shell; never commit them.

TEST_DATABASE_URL="postgresql://<role>:<password>@<test-branch-host>.neon.tech/<database>?sslmode=require"
# Optional but recommended for reset-test-db safety checks:
TEST_DATABASE_BRANCH_ID="br-..."
TEST_DATABASE_BRANCH_NAME="test"
TEST_DATABASE_ENDPOINT_HOST="ep-...-pooler.<region>.aws.neon.tech"
